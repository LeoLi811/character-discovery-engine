{
  "name": "game-character-catalog",
  "version": "0.1.0",
  "private": true,
    "scripts": {
    "dev": "next dev",
    "dev:local": "cscript //nologo scripts/start-local-dev.vbs",
    "build": "npm run validate:data && next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "validate:data": "node scripts/validate-characters.mjs && node scripts/validate-discovery-data.mjs",
    "validate:discovery": "node scripts/validate-discovery-data.mjs",
    "export:csv": "node scripts/export-characters-csv.mjs"
  },
  "dependencies": {
    "lucide-react": "latest",
    "next": "latest",
    "react": "latest",
    "react-dom": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "eslint": "latest",
    "eslint-config-next": "latest",
    "typescript": "latest"
  }
}
